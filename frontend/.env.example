# Development environment variables
# In development, Vite proxy handles API calls to localhost:5000
# No need to set VITE_BACKEND_URL in development

# Production environment variables
# Set this to your deployed backend URL (without /api suffix)
# VITE_BACKEND_URL=https://your-backend-domain.onrender.com

# Examples:
# For Render backend: VITE_BACKEND_URL=https://animeko-backend.onrender.com
# For Railway backend: VITE_BACKEND_URL=https://animeko-backend.railway.app
# For custom domain: VITE_BACKEND_URL=https://api.yourdomain.com
